# Sao chép file này: cp .env.example .env.local
# Điền key tại Supabase → Project Settings → API

# --- App ---
NEXT_PUBLIC_API_BASE_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME=FarmGo

# --- Supabase (bắt buộc) ---
# Project URL — ví dụ: https://abcdefgh.supabase.co
# Chỉ domain gốc — KHÔNG thêm /rest/v1/
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co

# anon public — client / Server Components (có RLS)
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# service_role — CHỈ dùng trên server, KHÔNG đưa vào client
# Không commit, không đặt NEXT_PUBLIC_
SUPABASE_SERVICE_ROLE_KEY=
